// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — HVAC Cost Estimator (Multi-Tenant SaaS)
// Database: PostgreSQL  |  ORM: Prisma
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN      // Full access: manage users, pricing, all projects
  ESTIMATOR  // Create/edit estimates and projects
  VIEWER     // Read-only access to projects and estimates
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ProjectStatus {
  ACTIVE
  WON
  LOST
  ON_HOLD
  ARCHIVED
}

enum ModuleType {
  UNIT_SCHEDULE
  METAL_DUCT
  CW_PIPE
  VAV_SCHEDULE
  ELECTRIC_HEAT
  FAN_SCHEDULE
  LOUVERS_DAMPERS
  DIFFUSER_SCHEDULE
  SUMMARY
}

enum RfqStatus {
  DRAFT
  SENT
  RECEIVED
  AWARDED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  RECEIVED
  ACCEPTED
  REJECTED
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT / AUTH MODELS
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  address     String?
  phone       String?
  email       String?
  logoUrl     String?  @map("logo_url")
  licenseNum  String?  @map("license_num")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  // Relations
  users         User[]
  invites       Invite[]
  projects      Project[]
  suppliers     Supplier[]
  pricingConfig PricingConfig?
  priceHistory  PriceHistory[]
  reports       Report[]

  @@map("companies")
}

model User {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  email        String
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  role         Role     @default(ESTIMATOR)
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  // Relations
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  projects      Project[]      @relation("ProjectCreator")
  estimates     Estimate[]     @relation("EstimateCreator")
  changelogs    ProjectChangelog[]

  @@unique([companyId, email])
  @@index([companyId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Invite {
  id          String       @id @default(cuid())
  companyId   String       @map("company_id")
  email       String
  role        Role         @default(ESTIMATOR)
  token       String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  invitedById String?      @map("invited_by_id")
  expiresAt   DateTime     @map("expires_at")
  acceptedAt  DateTime?    @map("accepted_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([token])
  @@map("invites")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECT MODELS
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  companyId   String        @map("company_id")
  createdById String?       @map("created_by_id")

  // Core fields (mirrors existing SQLite projects table)
  name        String
  location    String?
  owner       String?       // Property owner name
  gc          String?       // General contractor
  bidDate     DateTime?     @map("bid_date")
  status      ProjectStatus @default(ACTIVE)
  notes       String?

  // Company info snapshot at time of bid
  companyName    String? @map("company_name")
  companyAddress String? @map("company_address")
  companyPhone   String? @map("company_phone")
  companyEmail   String? @map("company_email")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User?     @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  contacts   ProjectContact[]
  estimates  Estimate[]
  scenarios  Scenario[]
  changelogs ProjectChangelog[]
  reports    Report[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("projects")
}

model ProjectContact {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  name      String
  role      String? // e.g. "Architect", "Owner Rep", "GC PM"
  email     String?
  phone     String?
  isPrimary Boolean @default(false) @map("is_primary")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_contacts")
}

model ProjectChangelog {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String?  @map("user_id")
  action    String   // e.g. "estimate_updated", "status_changed"
  detail    Json?    // arbitrary diff/details as JSONB
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("project_changelogs")
}

// A Scenario is an alternate version of a project's estimates
// (e.g., "Base Bid" vs "Alternate 1")
model Scenario {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String   @default("Base Bid")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  estimates Estimate[]

  @@index([projectId])
  @@map("scenarios")
}

// ─────────────────────────────────────────────────────────────────────────────
// ESTIMATE MODELS
// ─────────────────────────────────────────────────────────────────────────────

// One Estimate per project+module (+optional scenario)
model Estimate {
  id          String     @id @default(cuid())
  projectId   String     @map("project_id")
  scenarioId  String?    @map("scenario_id")
  createdById String?    @map("created_by_id")
  module      ModuleType

  // Rolled-up totals (denormalized for fast dashboard queries)
  totalMaterial  Decimal? @map("total_material") @db.Decimal(12, 2)
  totalLabor     Decimal? @map("total_labor")    @db.Decimal(12, 2)
  totalHours     Decimal? @map("total_hours")    @db.Decimal(10, 2)
  totalCost      Decimal? @map("total_cost")     @db.Decimal(12, 2)

  // Module-level settings stored as JSONB
  // e.g. techRates, priceOverrides, ductGlobals, etc.
  settings   Json? @default("{}")

  // Legacy/migration: full rows+prices+totals stored as raw JSON
  // (kept for backward-compat while migrating; can be removed once all
  //  modules use EstimateRow)
  rowsJson   Json? @map("rows_json")
  pricesJson Json? @map("prices_json")
  totalsJson Json? @map("totals_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenario  Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("EstimateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  rows      EstimateRow[]

  @@unique([projectId, scenarioId, module])
  @@index([projectId])
  @@map("estimates")
}

// One row per equipment/duct/pipe line item within an estimate
model EstimateRow {
  id         String @id @default(cuid())
  estimateId String @map("estimate_id")
  sortOrder  Int    @default(0) @map("sort_order")

  // All user-entered fields for this row stored as JSONB
  // e.g. { unitType, qty, tons, accessories, techRate, priceOverrides, ... }
  rowData    Json @map("row_data")

  // Computed output fields as JSONB
  // e.g. { material, labor, hours, breakdown, ... }
  resultData Json? @map("result_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
  @@index([estimateId, sortOrder])
  @@map("estimate_rows")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRICING MODELS
// ─────────────────────────────────────────────────────────────────────────────

// Per-company pricing configuration (one row per company)
model PricingConfig {
  id        String @id @default(cuid())
  companyId String @unique @map("company_id")

  // Labor rates ($/hr) per trade
  ratePackaged  Decimal @default(25) @map("rate_packaged")  @db.Decimal(8, 2)
  rateSplit     Decimal @default(65) @map("rate_split")     @db.Decimal(8, 2)
  rateWallMount Decimal @default(65) @map("rate_wall_mount") @db.Decimal(8, 2)
  rateVrf       Decimal @default(75) @map("rate_vrf")       @db.Decimal(8, 2)
  rateFan       Decimal @default(25) @map("rate_fan")       @db.Decimal(8, 2)
  rateDuct      Decimal @default(25) @map("rate_duct")      @db.Decimal(8, 2)
  ratePipe      Decimal @default(65) @map("rate_pipe")      @db.Decimal(8, 2)
  rateElec      Decimal @default(65) @map("rate_elec")      @db.Decimal(8, 2)

  // Overhead & margin
  overheadPct Decimal @default(0.15) @map("overhead_pct") @db.Decimal(5, 4)
  profitPct   Decimal @default(0.10) @map("profit_pct")   @db.Decimal(5, 4)
  taxPct      Decimal @default(0.00) @map("tax_pct")      @db.Decimal(5, 4)

  // Material waste factors
  ductWastePct Decimal @default(0.10) @map("duct_waste_pct") @db.Decimal(5, 4)
  pipeWastePct Decimal @default(0.10) @map("pipe_waste_pct") @db.Decimal(5, 4)

  // Accessory price overrides (flat JSON map of key → price)
  // e.g. { "packaged": { "thermostat": 250 }, "split": { "pvcCond": 80 } }
  accessoryOverrides Json @default("{}") @map("accessory_overrides")

  // Full pricing tables stored as JSONB (overridable lookup tables)
  // Each key mirrors the lookup tables in unitScheduleCalculations.js
  unitPricingTables Json? @map("unit_pricing_tables")
  ductPricingTables Json? @map("duct_pricing_tables")
  pipePricingTables Json? @map("pipe_pricing_tables")
  fanPricingTables  Json? @map("fan_pricing_tables")
  diffuserPricing   Json? @map("diffuser_pricing")
  louverPricing     Json? @map("louver_pricing")

  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("pricing_configs")
}

// Historical pricing snapshots (replaces SQLite price_history table)
model PriceHistory {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  source     String?  // e.g. "manual", "supplier_import", "api"
  pricesJson Json     @map("prices_json")
  fetchedAt  DateTime @default(now()) @map("fetched_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, fetchedAt(sort: Desc)])
  @@map("price_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPLIER & RFQ MODELS
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id        String  @id @default(cuid())
  companyId String  @map("company_id")
  name      String
  company   String? // supplier's company name
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rfqSuppliers  RfqSupplier[]
  quotes        SupplierQuote[]

  @@index([companyId])
  @@map("suppliers")
}

model Rfq {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  projectId   String?   @map("project_id")
  title       String
  projectName String?   @map("project_name")
  itemsJson   Json      @map("items_json")   // array of line items
  status      RfqStatus @default(DRAFT)
  sentAt      DateTime? @map("sent_at")
  dueDate     DateTime? @map("due_date")
  notes       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  suppliers RfqSupplier[]
  quotes    SupplierQuote[]

  @@index([companyId])
  @@index([projectId])
  @@map("rfqs")
}

// Join table: which suppliers are included in an RFQ
model RfqSupplier {
  rfqId      String @map("rfq_id")
  supplierId String @map("supplier_id")

  rfq      Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([rfqId, supplierId])
  @@map("rfq_suppliers")
}

model SupplierQuote {
  id         String      @id @default(cuid())
  rfqId      String      @map("rfq_id")
  supplierId String      @map("supplier_id")
  linesJson  Json        @map("lines_json")   // quoted line items with prices
  subtotal   Decimal?    @db.Decimal(12, 2)
  notes      String?
  status     QuoteStatus @default(PENDING)
  receivedAt DateTime?   @map("received_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  rfq      Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([rfqId, supplierId])
  @@index([rfqId])
  @@map("supplier_quotes")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORTS & PROPOSALS
// ─────────────────────────────────────────────────────────────────────────────

model Report {
  id          String  @id @default(cuid())
  companyId   String  @map("company_id")
  projectId   String  @map("project_id")
  type        String  // "proposal", "summary", "rfq", "bid_sheet"
  filename    String
  storagePath String? @map("storage_path") // S3/R2 key or local path
  totalBid    Decimal? @map("total_bid") @db.Decimal(12, 2)
  metadata    Json?   // any extra data (e.g. page count, version)

  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([projectId])
  @@map("reports")
}
