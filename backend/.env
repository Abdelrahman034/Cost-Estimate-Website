# ─────────────────────────────────────────────────────────────
#  HVAC Cost Estimator — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── AI: Groq (FREE — no credit card required) ─────────────────
# Sign up at https://console.groq.com
# Click "API Keys" → "Create API Key" → paste it below
GROQ_API_KEY=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

# ── Email (optional — only needed for RFQ / proposal emails) ──
# For Gmail: enable 2FA → Google Account → Security → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM_NAME=HVAC Estimating

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ───────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/hvac_estimator"

# ── JWT Auth ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-to-a-random-secret
JWT_REFRESH_SECRET=change-this-to-another-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
