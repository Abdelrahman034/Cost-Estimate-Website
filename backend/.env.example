# ─────────────────────────────────────────────────────────────
#  HVAC Cost Estimator — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── AI: Groq (FREE — no credit card required) ─────────────────
# Sign up at https://console.groq.com
# Click "API Keys" → "Create API Key" → paste it below
GROQ_API_KEY=your_groq_api_key_here

# ── Email (optional — only needed for RFQ / proposal emails) ──
# For Gmail: enable 2FA → Google Account → Security → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM_NAME=HVAC Estimating

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ───────────────────────────
# Replace with your Neon / Railway / Supabase connection string
# Get from: https://neon.tech  or  https://railway.app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hvac_estimator?schema=public&sslmode=require"

# ── JWT Auth ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-token-secret-here
JWT_REFRESH_SECRET=your-refresh-token-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
