# ─────────────────────────────────────────────────────────────
#  HVAC Cost Estimator — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── AI: Groq (FREE — no credit card required) ─────────────────
# Sign up at https://console.groq.com
# Click "API Keys" → "Create API Key" → paste it below
GROQ_API_KEY=your_groq_api_key_here

# ── Email (optional — only needed for RFQ / proposal emails) ──
# For Gmail: enable 2FA → Google Account → Security → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM_NAME=HVAC Estimating

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────
# SQLite — no setup needed, file is auto-created at backend/data/estimator.db
# (nothing to configure here)
